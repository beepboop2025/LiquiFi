{
  "name": "liquifi-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:electron": "tsc -p tsconfig.electron.json",
    "electron:dev": "npm run build:electron && electron .",
    "electron:start": "npm run build:electron && BUILD_TARGET=electron vite build && electron .",
    "electron:prebuild": "rsync -a --exclude='venv' --exclude='__pycache__' --exclude='*.pyc' --exclude='logs' --exclude='metrics' --exclude='data/collected' --exclude='data/_cache' --exclude='tests' backend/ build-backend/",
    "electron:build": "npm run build:electron && BUILD_TARGET=electron vite build && npm run electron:prebuild && electron-builder --mac"
  },
  "dependencies": {
    "@babel/core": "^7.28.6",
    "@babel/generator": "^7.28.6",
    "@babel/helper-module-imports": "^7.28.6",
    "@babel/helper-module-transforms": "^7.28.6",
    "@babel/helpers": "^7.28.6",
    "@babel/parser": "^7.28.6",
    "@babel/template": "^7.28.6",
    "@babel/traverse": "^7.28.6",
    "@babel/types": "^7.28.6",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.10"
  },
  "build": {
    "appId": "com.liquifi.treasury",
    "productName": "LiquiFi",
    "mac": {
      "icon": "electron/icon.icns",
      "target": [
        "dmg",
        "dir"
      ],
      "category": "public.app-category.finance"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!electron/*.ts",
      "!electron/*.js.map"
    ],
    "extraResources": [
      {
        "from": "build-backend/",
        "to": "backend/"
      }
    ],
    "directories": {
      "output": "release"
    }
  }
}
