# LiquiFi Backend - Environment Variables
# Copy this file to .env and update the values

# =============================================================================
# Server Configuration
# =============================================================================
LIQUIFI_ENV=production
LIQUIFI_HOST=0.0.0.0
LIQUIFI_PORT=8000
LIQUIFI_CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
LIQUIFI_RETRAIN_KEY=your-secure-retrain-key-here
LIQUIFI_REQUIRE_HTTPS=true
LIQUIFI_RETRAIN_RATE_LIMIT=2

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================
POSTGRES_USER=liquifi
POSTGRES_PASSWORD=change-this-secure-password
POSTGRES_DB=liquifi
DATABASE_URL=postgresql://liquifi:change-this-secure-password@postgres:5432/liquifi

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# =============================================================================
# External API Keys
# =============================================================================
# Get your free API key from: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your-fred-api-key-here

# =============================================================================
# Optional: Advanced Configuration
# =============================================================================
# SCRAPE_INTERVAL_S=30
# RATE_PUSH_INTERVAL_S=3
# AUTO_RETRAIN_INTERVAL_S=3600
# MC_PATHS=300
